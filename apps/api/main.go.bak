package main

import (
	"fmt"
	"log"
	"net/http"
)

func main() {
	port := ":8080"
	
	http.HandleFunc("/health", func(w http.ResponseWriter, r *http.Request) {
		fmt.Fprintf(w, "OK")
	})

	log.Printf("Pluto API starting on %s...", port)
	if err := http.ListenAndServe(port, nil); err != nil {
		log.Fatalf("Server failed: %s", err)
	}
}
